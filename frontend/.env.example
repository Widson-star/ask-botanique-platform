# Supabase — get these from your Supabase project settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL — leave empty for local dev (Vite proxy handles it)
# In production set this to your Render backend URL e.g. https://ask-botanique-api.onrender.com
VITE_API_URL=
